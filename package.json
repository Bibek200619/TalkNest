{
  "name": "talknest",
  "version": "0.1.0",
  "private": true,
  "description": "TalkNest real-time chat monorepo.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n server,web,mobile -c blue,green,magenta \"npm run dev -w @talknest/server\" \"npm run dev -w @talknest/web\" \"npm run web -w @talknest/mobile\"",
    "dev:server": "npm run dev -w @talknest/server",
    "dev:web": "npm run dev -w @talknest/web",
    "dev:mobile": "npm run start -w @talknest/mobile",
    "deploy:vercel": "npx vercel@54.18.7 --prod",
    "build": "npm run build -w @talknest/server && npm run build -w @talknest/web",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:visual:web": "npm run test:visual -w @talknest/web",
    "verify": "npm run typecheck && npm run test && npm run build",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "prettier": "^3.6.2",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
